# ── Dart / Flutter tool cache ─────────────────────────────────────────────────
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/

# ── Build output ──────────────────────────────────────────────────────────────
/build/

# ── Platforms NOT in use (desktop) ───────────────────────────────────────────
/linux/
/macos/
/windows/

# ── Android — secrets & generated files ──────────────────────────────────────
#
# COMMIT (needed for build):
#   android/app/build.gradle
#   android/app/src/main/AndroidManifest.xml
#   android/app/src/main/kotlin/
#   android/app/src/main/res/
#   android/build.gradle
#   android/settings.gradle
#   android/gradle.properties
#   android/gradle/wrapper/gradle-wrapper.properties
#   android/gradle/wrapper/gradle-wrapper.jar
#   android/gradlew + gradlew.bat
#
# IGNORE (secrets & machine-specific):
android/key.properties
android/local.properties
*.jks
*.keystore

# ── iOS ───────────────────────────────────────────────────────────────────────
#
# COMMIT (needed for clone-and-run):
#   ios/Runner/                           ← app config, storyboards, Info.plist
#   ios/Runner.xcodeproj/project.pbxproj  ← Xcode project definition
#   ios/Runner.xcworkspace/contents.xcworkspacedata
#   ios/Podfile                           ← CocoaPods dependency declaration
#   ios/Podfile.lock                      ← reproducible pod versions
#   ios/Flutter/AppFrameworkInfo.plist
#   ios/Flutter/Debug.xcconfig
#   ios/Flutter/Release.xcconfig
#
# IGNORE (generated per-machine or per-build):

# CocoaPods downloaded packages (re-generated by `pod install`)
ios/Pods/
ios/.symlinks/

# Flutter-generated Xcode configs (created by `flutter build` / `flutter run`)
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec
ios/Flutter/.last_build_id
ios/Flutter/Generated.xcconfig
ios/Flutter/flutter_export_environment.sh
ios/Flutter/ephemeral/

# Xcode user-specific & machine-specific settings
ios/Runner.xcodeproj/xcuserdata/
ios/Runner.xcworkspace/xcuserdata/
ios/Runner.xcworkspace/xcshareddata/WorkspaceSettings.xcsettings

# ── IDE ───────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.iml
*.ipr
*.iws

# ── macOS filesystem noise ────────────────────────────────────────────────────
.DS_Store
**/.DS_Store

# ── Dart / JS analysis artefacts ─────────────────────────────────────────────
*.dart.js
*.js_
*.js.deps
*.js.map

# ── Logs & crash reports ──────────────────────────────────────────────────────
*.log
