# Dart/Flutter generated tool files
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/

# Build output — never commit
/build/

# Platform runner boilerplate generated by "flutter create"
# Commit these if you want to customise native code, otherwise ignore
/android/
/linux/
/macos/

# iOS — CocoaPods lock and Pods folder (pod install regenerates them)
ios/Pods/
ios/.symlinks/
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec
ios/Flutter/.last_build_id

# Windows — generated runner (commit if you need custom native Windows code)
# /windows/

# IDE
.idea/
.vscode/
*.iml
*.ipr
*.iws

# macOS filesystem noise
.DS_Store

# Dart analysis
*.dart.js
*.js_
*.js.deps
*.js.map
